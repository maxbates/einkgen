# OpenAI key (used by the generator Lambda + `einkgen local generate/preview`)
OPENAI_API_KEY=sk-...

# AWS profile (boto3 picks this up via AWS_PROFILE)
AWS_PROFILE=einkgen

# Target S3 bucket for the pipeline
EINKGEN_BUCKET=einkgen-dev

# Public CDN base URL fronting the bucket's `current/` prefix.
# Used to build the manifest's `image_url`.
EINKGEN_CDN_BASE=https://cdn.example.com

# CloudFront distribution ID. When set, publish() invalidates
# /current/manifest.json and /current/image.bmp after each write.
EINKGEN_CF_DISTRIBUTION_ID=
