# einkgen web app — build-time configuration.
# Copy to `.env.local` for local dev (or `.env.production` for prod builds).
# Both are read by Vite as `import.meta.env.VITE_*`.

# URL of the einkgen-read-api Lambda Function URL.
# Local dev default points at a locally-running stub.
VITE_READ_API_URL=http://localhost:3001

# Public CloudFront base URL where the S3 bucket is fronted.
# Used to load history BMPs and queue image thumbnails directly.
# In prod this is the CloudFront distribution domain (no trailing slash).
VITE_CDN_BASE=http://localhost:3001/cdn
